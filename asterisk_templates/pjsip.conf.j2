; ===========================================
; Millicall PBX - PJSIP Configuration
; Auto-generated - DO NOT EDIT MANUALLY
; ===========================================

; --- Transport ---
[transport-udp]
type=transport
protocol=udp
bind={{ bind_address }}:5060

[transport-tcp]
type=transport
protocol=tcp
bind={{ bind_address }}:5060

{% for peer in peers %}
; --- Peer: {{ peer.username }} ---
[{{ peer.username }}]
type=endpoint
context=internal
disallow=all
{% for codec in peer.codecs %}
allow={{ codec }}
{% endfor %}
auth={{ peer.username }}
aors={{ peer.username }}
direct_media=no
rtp_symmetric=yes
force_rport=yes
rewrite_contact=yes

[{{ peer.username }}]
type=auth
auth_type=userpass
username={{ peer.username }}
password={{ peer.password }}

[{{ peer.username }}]
type=aor
max_contacts=5
remove_existing=yes
{% if peer.ip_address %}
contact=sip:{{ peer.ip_address }}
{% endif %}
default_expiration=3600
minimum_expiration=60

{% endfor %}

{% for trunk in trunks %}
; ===========================================
; PSTN Trunk: {{ trunk.display_name }} ({{ trunk.name }})
; ===========================================

[{{ trunk.name }}]
type=registration
outbound_auth={{ trunk.name }}-auth
server_uri=sip:{{ trunk.host }}
client_uri=sip:{{ trunk.username }}@{{ trunk.host }}
contact_user={{ trunk.username }}
retry_interval=60
expiration=3600

[{{ trunk.name }}-auth]
type=auth
auth_type=userpass
username={{ trunk.username }}
password={{ trunk.password }}

[{{ trunk.name }}]
type=aor
contact=sip:{{ trunk.host }}

[{{ trunk.name }}]
type=endpoint
context=from-pstn-{{ trunk.name }}
disallow=all
allow=ulaw
allow=alaw
outbound_auth={{ trunk.name }}-auth
aors={{ trunk.name }}
from_user={{ trunk.username }}
from_domain={{ trunk.host }}
direct_media=no
rtp_symmetric=yes
rewrite_contact=yes
force_rport=yes
trust_id_inbound=yes
send_pai=yes
send_rpid=yes
callerid_tag={{ trunk.name }}
set_var=SIPUSERAGENT=IPphone1

[{{ trunk.name }}-identify]
type=identify
endpoint={{ trunk.name }}
match={{ trunk.host }}/255.255.255.255

{% endfor %}
