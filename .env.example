# =============================================================================
# Millicall PBX — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control!
# =============================================================================

# --- Database ----------------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./data/millicall.db

# --- Asterisk paths ---------------------------------------------------------
ASTERISK_CONFIG_DIR=/etc/asterisk
ASTERISK_TEMPLATES_DIR=/app/asterisk_templates

# --- Network ----------------------------------------------------------------
PBX_BIND_ADDRESS=0.0.0.0
WEB_HOST=0.0.0.0
WEB_PORT=8000

# --- Security (REQUIRED — no insecure defaults) -----------------------------
# JWT signing secret. Use a long random string (64+ chars recommended).
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=

# Initial admin user password. Change this immediately after first login.
ADMIN_PASSWORD=

# Password used for WebRTC SIP registration.
WEBRTC_PASSWORD=

# --- Asterisk REST Interface (ARI) ------------------------------------------
# Must match the credentials in ari.conf (auto-generated from ari.conf.j2).
ARI_USER=millicall
ARI_PASSWORD=

# --- LLM / AI API Keys (set the ones you use) -------------------------------
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- TTS: CoeFont (optional) ------------------------------------------------
COEFONT_ACCESS_KEY=
COEFONT_ACCESS_SECRET=
COEFONT_VOICE_ID=

# --- Cloudflare Tunnel (optional, for remote access) -------------------------
CLOUDFLARE_TUNNEL_TOKEN=
